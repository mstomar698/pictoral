{
  "name": "image-editor",
  "version": "1.2.0",
  "description": "Web frontend for the Pictoral Rust/WASM image editor",
  "private": true,
  "scripts": {
    "dev": "webpack serve --config webpack.config.js",
    "build": "npm run clean && webpack --config webpack.config.production.js",
    "clean": "node clean.js",
    "start": "webpack serve --config webpack.config.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-class-properties": "^8.0.1",
    "@babel/plugin-transform-regenerator": "^8.0.2",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.1.1",
    "postcss-preset-env": "^11.3.1",
    "rimraf": "^6.0.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.3.1",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.6.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "webpack": "^5.99.9",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "@reduxjs/toolkit": "^2.8.2",
    "axios": "^1.9.0",
    "immutable": "^5.1.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.17.0",
    "react-toastify": "^11.0.5",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "uuid": "^11.1.0"
  }
}
